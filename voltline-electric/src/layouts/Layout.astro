---
import "../styles/global.css";
// Main pages get their SEO tags injected automatically by Wix; item pages fill
// the `seo-tags` slot below via <SEO.Tags>. Per the item-page SEO guide, we do
// NOT hard-code a fallback <title>/<meta description> here (it would duplicate
// the injected tags on main pages).
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Caveat:wght@600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <slot name="seo-tags" />
  </head>
  <body>
    <slot />
  </body>
</html>
