---
// Line icon chosen by service slug (falls back to a bolt).
interface Props { slug: string }
const { slug } = Astro.props;

const common = 'fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"';
const icons: Record<string, string> = {
  "emergency-callout": `<path d="M13 2 4 14h7l-1 8 9-12h-7z"/>`,
  "consumer-unit-upgrade": `<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 4v16M8 8H3M8 13H3M13 8h4M13 12h4M13 16h4"/>`,
  "ev-charger-installation": `<path d="M5 20V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v14"/><path d="M4 20h12"/><path d="M15 9h2a2 2 0 0 1 2 2v4a1.5 1.5 0 0 0 3 0V8l-2-2"/><path d="M10 8 8 12h3l-2 4"/>`,
  "rewire-consultation": `<rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 3V2h6v1"/><path d="M9 9h6M9 13h6M9 17h3"/>`,
  "lighting-design-fit": `<path d="M9 18h6M10 21h4"/><path d="M12 3a6 6 0 0 0-4 10.5c.8.8 1 1.2 1 2.5h6c0-1.3.2-1.7 1-2.5A6 6 0 0 0 12 3Z"/>`,
  "eicr-safety-inspection": `<path d="M12 3 4 6v6c0 5 3.5 7.5 8 9 4.5-1.5 8-4 8-9V6z"/><path d="m9 12 2 2 4-4"/>`,
};
const path = icons[slug] ?? icons["emergency-callout"];
---
<svg xmlns="http://www.w3.org/2000/svg" set:html={path} fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"></svg>
